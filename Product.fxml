<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="500.0" prefWidth="700.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="supermarket_db.ProductController">

    <!-- Product Name -->
    <Label layoutX="20" layoutY="20" text="Product Name:" />
    <TextField fx:id="txtName" layoutX="150" layoutY="16" prefWidth="200" />

    <!-- Barcode -->
    <Label layoutX="20" layoutY="60" text="Barcode:" />
    <TextField fx:id="txtBarcode" layoutX="150" layoutY="56" prefWidth="200" />

    <!-- Retail Price -->
    <Label layoutX="20" layoutY="100" text="Retail Price:" />
    <TextField fx:id="txtRetail" layoutX="150" layoutY="96" prefWidth="200" />

    <!-- Cost Price -->
    <Label layoutX="20" layoutY="140" text="Cost Price:" />
    <TextField fx:id="txtCost" layoutX="150" layoutY="136" prefWidth="200" />

    <!-- Category ID -->
    <Label layoutX="20" layoutY="180" text="Category ID:" />
    <TextField fx:id="txtCategory" layoutX="150" layoutY="176" prefWidth="200" />

    <!-- Button -->
    <Button layoutX="150" layoutY="220" onAction="#addProduct" text="Add Product" />

    <!-- Table -->
    <TableView fx:id="productTable" layoutX="20" layoutY="270" prefHeight="200" prefWidth="650">

        <columns>
            <TableColumn fx:id="colName" prefWidth="150" text="Name" />
            <TableColumn fx:id="colBarcode" prefWidth="150" text="Barcode" />
            <TableColumn fx:id="colRetail" prefWidth="120" text="Retail Price" />
            <TableColumn fx:id="colCost" prefWidth="120" text="Cost Price" />
            <TableColumn fx:id="colCategory" prefWidth="110" text="Category ID" />
        </columns>

    </TableView>
   <Button layoutX="266.0" layoutY="220.0" mnemonicParsing="false" onAction="#deleteProduct" text="Delete Product" />
   <Label layoutX="389.0" layoutY="20.0" text="Search:" />
   <TextField fx:id="txtSearch" layoutX="435.0" layoutY="16.0" />
   <Button layoutX="597.0" layoutY="16.0" mnemonicParsing="false" onAction="#searchProduct" text="Search" />
   <Label layoutX="393.0" layoutY="88.0" text="Update Product" />
   <Button layoutX="491.0" layoutY="84.0" mnemonicParsing="false" onAction="#updateProduct" text="Update" />

</AnchorPane>