<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane
prefHeight="400.0"
prefWidth="600.0"
xmlns="http://javafx.com/javafx/26"
xmlns:fx="http://javafx.com/fxml/1"
fx:controller="supermarket_db.CategoryController">

   <children>
      <Label layoutX="27.0" layoutY="25.0" text="Category Name" />
      <TextField fx:id="txtName" layoutX="122.0" layoutY="21.0" />
      <Button layoutX="27.0" layoutY="79.0" mnemonicParsing="false" onAction="#addCategory" prefHeight="31.0" prefWidth="116.0" text="Add Category" />
      <Button layoutX="165.0" layoutY="79.0" mnemonicParsing="false" onAction="#deleteCategory" prefHeight="31.0" prefWidth="116.0" text="Delete Category" />
      <Button layoutX="517.0" layoutY="18.0" mnemonicParsing="false" onAction="#searchCategory" prefHeight="31.0" prefWidth="63.0" text="Search " />
      <Label layoutX="311.0" layoutY="25.0" text="Search:" />
      <TextField fx:id="txtSearch" layoutX="358.0" layoutY="21.0" />
      <Button layoutX="300.0" layoutY="79.0" mnemonicParsing="false" onAction="#updateCategory" prefHeight="31.0" prefWidth="116.0" text="Update Category" />
      <TableView fx:id="categoryTable" layoutX="28.0" layoutY="144.0" prefHeight="207.0" prefWidth="545.0">
        <columns>
          <TableColumn fx:id="colid" prefWidth="75.0" text="Category ID" />
          <TableColumn fx:id="colname" prefWidth="131.0" text="Category Name" />
        </columns>
      </TableView>
   </children>
</AnchorPane>