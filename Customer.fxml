<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="600.0" prefWidth="900.0"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="supermarket_db.CustomerController">

    <!-- FORM -->
    <VBox layoutX="20" layoutY="20" spacing="10">

        <Label text="Customer Management" style="-fx-font-size:18px; -fx-font-weight:bold;" />

        <HBox spacing="10">
            <TextField fx:id="idField" promptText="Customer ID (for search/update)" />
            <Button text="Search" onAction="#searchCustomer"/>
        </HBox>

        <TextField fx:id="nameField" promptText="Name"/>
        <TextField fx:id="phoneField" promptText="Phone"/>
        <TextField fx:id="emailField" promptText="Email"/>
        <TextField fx:id="addressField" promptText="Address"/>

        <DatePicker fx:id="datePicker" promptText="Registration Date"/>

        <HBox spacing="10">
            <Button text="Add" onAction="#addCustomer"/>
            <Button text="Update" onAction="#updateCustomer"/>
            <Button text="Delete" onAction="#deleteCustomer"/>
            <Button text="Clear" onAction="#clearFields"/>
        </HBox>

    </VBox>

    <!-- TABLE -->
    <TableView fx:id="customerTable" layoutX="350" layoutY="20" prefWidth="520" prefHeight="550">

        <columns>

            <TableColumn fx:id="colId" text="ID" prefWidth="60"/>
            <TableColumn fx:id="colName" text="Name" prefWidth="100"/>
            <TableColumn fx:id="colPhone" text="Phone" prefWidth="100"/>
            <TableColumn fx:id="colEmail" text="Email" prefWidth="120"/>
            <TableColumn fx:id="colAddress" text="Address" prefWidth="120"/>
            <TableColumn fx:id="colDate" text="Date" prefWidth="100"/>

        </columns>

    </TableView>

</AnchorPane>